# Local development only. Copy to .env; never commit .env.
# No quotes — Docker Compose and Make read these values.

# Database
DB_NAME=wordpress_local
DB_USER=wordpress_dev
DB_PASSWORD=local_db_change_me_42
DB_ROOT_PASSWORD=local_root_change_me_84

# Local ports
WP_PORT=80
PMA_PORT=8080

# Site (used by `make install`)
WP_URL=http://localhost
WP_TITLE=Local WordPress Workshop
WP_ADMIN_USER=site_admin
WP_ADMIN_PASSWORD=local_admin_change_me_73
WP_ADMIN_EMAIL=admin@example.test

# Copy to .env and adjust. Never commit .env.
# No quotes — values are read by both docker compose and the Makefile.

# Database
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=wordpress
DB_ROOT_PASSWORD=root

# Site (used by `make install`)
WP_URL=http://localhost:8080
WP_TITLE=WordPress Starter
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@example.com
